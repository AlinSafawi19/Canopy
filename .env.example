# Public app URL (used for sitemap and robots.txt absolute URLs)
NEXT_PUBLIC_APP_URL=

# PostgreSQL connection string (Docker: use port 5433 to avoid conflict with local postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/cms_app"

# Seed credentials — if not set, seed generates a random password and shows it in console
SEED_OWNER_PASSWORD=
SEED_OWNER_EMAIL=admin@example.com

# JWT secret - must be at least 32 chars; generate with: openssl rand -hex 32
JWT_SECRET="REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32"

# Upstash Redis — required for multi-instance rate limiting (Vercel, containers, etc.)
# Create a free database at https://console.upstash.com and copy the REST credentials.
# Without these, rate limiting falls back to in-process memory (single instance only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — transactional email (https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="onboarding@resend.dev"

# Pusher — real-time collaborative editing (https://pusher.com)
# Create a Channels app, then copy the credentials from App Keys.
# NEXT_PUBLIC_ vars are exposed to the browser; the others are server-only.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Google Cloud Storage uploads
GOOGLE_CLOUD_BUCKET="your-bucket-name"
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}'
