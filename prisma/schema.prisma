generator client {
  provider = "prisma-client-js"
}

generator typedClient {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String    @id
  tenantId    String
  name        String    @db.VarChar(100)
  slug        String?   @db.VarChar(100)
  industry    String?   @db.VarChar(100)
  overview    String    @db.Text
  thumbnail_video String?   @db.VarChar(500)
  thumbnail_image String?   @db.VarChar(500)
  thumbnail_type  String?   @db.VarChar(10)
  categories  Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  updatedBy   String?
  archivedAt  DateTime?
  archivedBy  String?
  domain        String?   @db.VarChar(255)
  host          String?   @db.VarChar(100)
  adminTenantId String    @default("platform-default")

  tagline          String?   @db.VarChar(200)
  techStack        Json      @default("[]")
  githubUrl        String?   @db.VarChar(500)
  liveUrl          String?   @db.VarChar(500)
  role             String?   @db.VarChar(100)
  featured         Boolean   @default(false)
  status           String    @default("live") @db.VarChar(20)
  startDate        DateTime?
  endDate          DateTime?
  thumbnail_alt    String?   @db.VarChar(200)
  teamSize         String?   @db.VarChar(20)
  highlights       String[]
  challenge        String?   @db.Text
  approach         String?   @db.Text
  outcome          String?   @db.Text
  testimonial      String?   @db.Text

  contentCategories ContentCategory[]
  clientAssignment  ClientAssignment?

  @@index([archivedAt])
  @@index([slug])
  @@index([adminTenantId])
}

model ContentCategory {
  id          String    @id
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String    @db.VarChar(100)
  slug        String?   @db.VarChar(100)
  description String?   @db.VarChar(500)
  iconName    String?
  iconIndex   Int?
  defaults    Json?
  fields      Json
  previewUrl  String?   @db.VarChar(500)
  archivedAt  DateTime?
  archivedBy  String?
  entries     ContentCategoryEntry[]
  webhooks    Webhook[]

  @@index([projectId])
}

model Webhook {
  id              String          @id @default(cuid())
  categoryId      String
  category        ContentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name            String          @db.VarChar(100)
  url             String          @db.VarChar(500)
  secret          String          @db.VarChar(255)
  events          Json            @default("[\"entry.created\",\"entry.updated\",\"entry.archived\"]")
  enabled         Boolean         @default(true)
  createdAt       DateTime        @default(now())
  lastTriggeredAt DateTime?
  lastStatus      Int?

  @@index([categoryId])
}

model ContentCategoryEntry {
  id         String    @id
  categoryId String
  category   ContentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  values     Json
  sortIndex  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  archivedBy String?

  // Scheduled publishing / archiving
  publishAt        DateTime?
  archiveAt        DateTime?
  requiresApproval Boolean   @default(false)

  @@index([categoryId])
  @@index([categoryId, archivedAt])
  @@index([categoryId, updatedAt])
  @@index([publishAt])
  @@index([archiveAt])
}

model ClientIdentity {
  id                       String             @id
  tenantId                 String?
  username                 String             @unique @db.VarChar(30)
  password                 String
  name                     String             @db.VarChar(100)
  email                    String             @db.VarChar(255)
  theme                    String             @default("auto") @db.VarChar(10)
  updatedAt                DateTime           @updatedAt
  updatedBy                String?
  archivedAt               DateTime?
  archivedBy               String?
  slug                     String?            @unique
  walkthroughSeenAt        DateTime?
  emailVerifiedAt          DateTime?
  twoFactorSecret          String?
  twoFactorEnabled         Boolean            @default(false)
  mustShow2faReminder      Boolean            @default(true)
  lastSeenReleaseId        String?
  representativeName       String?            @db.VarChar(100)
  representativeDesignation String?           @db.VarChar(100)
  assignments              ClientAssignment[]

  @@index([tenantId])
  @@index([tenantId, archivedAt])
}

model ClientAssignment {
  id               String         @id
  clientId         String
  projectId        String         @unique
  tenantId         String
  updatedAt        DateTime       @updatedAt
  updatedBy        String?
  archivedAt       DateTime?
  archivedBy       String?
  client           ClientIdentity @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
}

model AdminIdentity {
  id                 String    @id
  username           String    @unique @db.VarChar(30)
  password           String
  displayName        String    @db.VarChar(50)
  email              String    @unique @default("") @db.VarChar(255)
  updatedAt          DateTime  @updatedAt
  updatedBy          String?
  theme              String    @default("auto") @db.VarChar(10)
  tenantId           String    @default("") @unique
  archivedAt         DateTime?
  archivedBy         String?
  walkthroughSeenAt  DateTime?
  emailVerifiedAt    DateTime?
  twoFactorSecret     String?
  twoFactorEnabled    Boolean   @default(false)
  mustShow2faReminder Boolean   @default(true)
  lastSeenReleaseId   String?
  createdByOwnerId    String?
  createdByOwner      PlatformOwner? @relation(fields: [createdByOwnerId], references: [id])

  @@index([archivedAt])
  @@index([createdByOwnerId])
}

model PlatformOwner {
  id                 String    @id
  username           String    @unique @db.VarChar(30)
  password           String
  displayName        String    @db.VarChar(50)
  email              String    @unique @default("") @db.VarChar(255)
  updatedAt          DateTime  @updatedAt
  updatedBy          String?
  theme              String    @default("auto") @db.VarChar(10)
  walkthroughSeenAt  DateTime?
  emailVerifiedAt    DateTime?
  twoFactorSecret      String?
  twoFactorEnabled     Boolean   @default(false)
  mustShow2faReminder  Boolean   @default(true)
  lastSeenReleaseId    String?
  admins               AdminIdentity[]
}

model TwoFactorBackupCode {
  id         String   @id @default(cuid())
  targetKind String
  targetId   String
  codeHash   String
  createdAt  DateTime @default(now())

  @@index([targetKind, targetId])
}

model PasswordResetChallenge {
  id         String   @id @default(cuid())
  targetKind String
  targetId   String
  codeHash   String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([targetKind, targetId])
  @@index([expiresAt])
}

model EmailVerificationChallenge {
  id         String   @id @default(cuid())
  targetKind String
  targetId   String
  codeHash   String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([targetKind, targetId])
  @@index([expiresAt])
}

model Contributor {
  id                   String    @id
  username             String    @db.VarChar(30)
  password             String
  displayName          String    @db.VarChar(50)
  email                String    @db.VarChar(255)
  tenantId             String
  parentClientUsername String
  permissions          Json
  theme                String    @default("auto") @db.VarChar(10)
  accountId            String
  updatedAt            DateTime  @updatedAt
  updatedBy            String?
  archivedAt           DateTime?
  archivedBy           String?
  walkthroughSeenAt    DateTime?
  emailVerifiedAt      DateTime?
  twoFactorSecret      String?
  twoFactorEnabled     Boolean   @default(false)
  mustShow2faReminder  Boolean   @default(true)
  lastSeenReleaseId    String?
  assignments          ContributorAssignment[]

  @@unique([tenantId, username])
  @@index([tenantId, parentClientUsername])
  @@index([accountId])
}

model ApiKey {
  id            String    @id @default(cuid())
  name          String    @db.VarChar(100)
  keyHash       String    @unique
  keyPrefix     String
  projectId     String
  adminTenantId String
  createdAt     DateTime  @default(now())
  expiresAt     DateTime? // null = no expiration (legacy), set to future date for new keys
  lastUsedAt    DateTime?
  revokedAt     DateTime?

  @@index([keyHash])
  @@index([projectId])
  @@index([expiresAt])
  @@index([adminTenantId])
}

model ContributorAssignment {
  id            String      @id @default(cuid())
  contributorId String
  projectId     String
  permissions   Json        @default("{}")
  contributor   Contributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([contributorId, projectId])
  @@index([contributorId])
  @@index([projectId])
}

model ActivityLog {
  id                   String   @id @default(cuid())
  actorId              String
  actorRole            String
  actorName            String
  action               String
  resource             String
  resourceId           String?
  resourceName         String?
  adminTenantId        String?
  parentClientUsername String?
  createdAt            DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([adminTenantId, createdAt])
  @@index([parentClientUsername, createdAt])
}

model InviteToken {
  id         String    @id @default(cuid())
  token      String    @unique
  targetKind String    // "admin" | "client" | "contributor"
  targetId   String
  usedAt     DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([token])
  @@index([targetKind, targetId])
}

model Release {
  id          String    @id @default(cuid())
  version     String
  title       String
  notes       String    @db.Text
  status      String    @default("draft")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String

  @@index([createdAt])
  @@index([status])
}

model PendingTwoFactorSetup {
  id         String   @id @default(cuid())
  targetKind String
  targetId   String
  secret     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@unique([targetKind, targetId])
  @@index([expiresAt])
}

model AccountLock {
  id          String    @id @default(cuid())
  targetKind  String
  targetId    String
  failedCount Int       @default(0)
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([targetKind, targetId])
}

model PasswordHistory {
  id         String   @id @default(cuid())
  targetKind String
  targetId   String
  passwordHash String
  createdAt  DateTime @default(now())

  @@index([targetKind, targetId, createdAt])
}

model Session {
  id             String   @id @default(cuid())
  targetKind     String
  targetId       String
  tokenHash      String
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now()) @updatedAt
  revokedAt      DateTime?

  @@index([targetKind, targetId])
  @@index([tokenHash])
  @@index([revokedAt])
}

model ChangeRequest {
  id             String    @id @default(cuid())
  entryId        String
  categoryId     String
  projectId      String
  authorId       String
  authorRole     String
  authorName     String
  note           String    @db.VarChar(1000)
  before         Json?
  after          Json?
  resolvedAt     DateTime?
  resolvedBy     String?
  resolvedByName String?
  createdAt      DateTime  @default(now())
  comments       ChangeRequestComment[]

  @@index([entryId])
  @@index([projectId, resolvedAt])
}

model ChangeRequestComment {
  id              String        @id @default(cuid())
  changeRequestId String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  authorId        String
  authorRole      String
  authorName      String
  body            String        @db.VarChar(2000)
  createdAt       DateTime      @default(now())

  @@index([changeRequestId, createdAt])
}

model Upload {
  id           String   @id @default(cuid())
  gcsUrl       String   @unique @db.VarChar(1000)
  uploadedBy   String
  uploaderRole String   @db.VarChar(20)
  projectId    String?
  createdAt    DateTime @default(now())

  @@index([uploadedBy])
  @@index([projectId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  String
  action     String
  resource   String
  severity   String   @default("info") // info, warning, critical
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([severity, createdAt])
}
